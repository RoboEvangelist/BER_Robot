<?xml version="1.0"?>
<launch>
  <!--motor control tells car where to move when person is detected. -->
  <node name="motor_control" pkg="motor_control" type="motor_control" output="screen">
  </node>

  <!--launch node to detect objects. -->
  <node name="object_detection_node" pkg="learning_image_transport" type="object_detection_node.py" output="screen">
  </node>

  <!--launch the CSI camera launch file--> 
  <include file="$(find jetson_csi_cam)/jetson_csi_cam.launch">
    <arg name="width" value="960" />
    <arg name="height" value="540" />
  </include>

  <!--launch node to detect objects. -->
  <node name="serial_node" pkg="rosserial_python" type="serial_node.py" output="screen">
    <param name="port" value="/dev/ttyACM0" />
  </node>


</launch>
